# VoxOfTheMists environment template
# Copy this file to .env and adjust values for your machine.

# Runtime
PORT=3000

# Snapshot automation
AUTO_SCRAPE=1
PYTHON_CMD=python

# Optional remote sync from Appwrite -> local SQLite (disabled by default)
APPWRITE_SYNC_ENABLED=0
APPWRITE_ENDPOINT=
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=
APPWRITE_SNAPSHOTS_COLLECTION_ID=
APPWRITE_ENTRIES_COLLECTION_ID=
APPWRITE_SYNC_INTERVAL_MINUTES=10
# 1 = run sync once per hour on a fixed UTC minute (recommended to reduce requests)
APPWRITE_SYNC_HOURLY_ALIGNED=1
# Minute of the hour in UTC when aligned hourly sync should run.
APPWRITE_SYNC_TARGET_MINUTE=12
# When Appwrite sync is enabled, disable local Python scraping to avoid duplicate snapshots.
APPWRITE_SYNC_DISABLE_LOCAL_SCRAPE=1

# Data retention / maintenance
# 0 = keep all snapshots forever (recommended for long-term progression)
RETENTION_DAYS=0
AUTO_VACUUM=1
VACUUM_MIN_HOURS=24
