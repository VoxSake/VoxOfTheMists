# VoxOfTheMists environment template
# Copy this file to .env and adjust values for your machine.

# Runtime
PORT=3000

# Local write-route protection
# Optional static token for local write endpoints (/api/snapshot/run, /api/sync/run, /api/maintenance/run).
# If empty, server generates a random token at startup.
WRITE_API_TOKEN=
# Optional comma-separated allowlist for browser Origin/Referer checks on local write/auth routes.
TRUSTED_LOCAL_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:5173,http://localhost:5173

# Local snapshot automation
# Runs Python scraper hourly. Ignored when Appwrite sync is enabled.
AUTO_SCRAPE=1
PYTHON_CMD=python

# Appwrite sync (remote -> local SQLite)
# When enabled, the server pulls snapshots from Appwrite instead of scraping locally.
# Recommended flow:
# - Appwrite function writes data around xx:00..xx:10
# - Local server sync pulls at xx:12 UTC
APPWRITE_SYNC_ENABLED=0
APPWRITE_ENDPOINT=https://cloud.appwrite.io
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=
APPWRITE_SNAPSHOTS_COLLECTION_ID=snapshots
APPWRITE_ENTRIES_COLLECTION_ID=entries

# 1 = sync once per hour at a fixed UTC minute (recommended).
# 0 = sync every APPWRITE_SYNC_INTERVAL_MINUTES instead.
APPWRITE_SYNC_HOURLY_ALIGNED=1
# UTC minute for hourly-aligned sync (should be after scraper finishes, e.g. 12).
APPWRITE_SYNC_TARGET_MINUTE=12
# Used only when APPWRITE_SYNC_HOURLY_ALIGNED=0.
APPWRITE_SYNC_INTERVAL_MINUTES=60

# Appwrite sync import tuning
# Number of snapshot IDs grouped per entries fetch during sync.
APPWRITE_SYNC_ENTRY_BATCH_SIZE=20

# Optional backfill guard:
# Set to 1 only if you explicitly want server-side function triggering.
# Default 0 because the Appwrite function can self-heal on its own schedule.
APPWRITE_BACKFILL_ENABLED=0
APPWRITE_BACKFILL_TARGET_MINUTE=30
# Function ID of your Appwrite scraper function (required when backfill is enabled).
APPWRITE_FUNCTION_ID=

# API cache tuning
# Max in-memory cache entries before pruning.
API_CACHE_MAX_ENTRIES=1000

# Data retention / maintenance
# 0 = keep all snapshots forever.
RETENTION_DAYS=0
AUTO_VACUUM=1
VACUUM_MIN_HOURS=24
