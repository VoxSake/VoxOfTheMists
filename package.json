{
  "name": "vox-of-the-mists",
  "version": "1.0.0",
  "private": true,
  "description": "GW2Mists leaderboard snapshot dashboard",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "cross-env NODE_ENV=development node server.js",
    "dev:web": "vite",
    "build": "vite build",
    "prestart": "npm run build",
    "start": "cross-env NODE_ENV=production node server.js",
    "start:api": "cross-env NODE_ENV=production node server.js"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.2.0",
    "chart.js": "^4.5.0",
    "chartjs-plugin-zoom": "^2.2.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.6.1",
    "hammerjs": "^2.0.8",
    "node-appwrite": "^14.2.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "vite": "^7.1.7"
  }
}
