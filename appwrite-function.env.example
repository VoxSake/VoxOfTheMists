# Appwrite Function env (scheduled ingestion writer)
# Use the "vox-ingest-writer" API key here.
APPWRITE_ENDPOINT=
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=
APPWRITE_SNAPSHOTS_COLLECTION_ID=
APPWRITE_ENTRIES_COLLECTION_ID=

# Scraper settings
GW2MISTS_REGION=eu
GW2MISTS_PAGES=3
GW2MISTS_PER_PAGE=100

# Safety switches
# 1 = skip insert if this hour snapshot already exists (recommended)
DEDUPE_HOURLY=1

# Slot selection
# Hourly slot timezone used for snapshotId/createdAt capture hour (default UTC).
SNAPSHOT_TIMEZONE=Europe/Brussels

# Optional reset policy (GW2 reset protection):
# - capture one pre-reset snapshot (e.g. 18:45 before 19:00 reset)
# - skip N hours after reset to let source data stabilize
RESET_POLICY_ENABLED=1
# 0=Monday ... 4=Friday ... 6=Sunday
RESET_WEEKDAY=4
# Reset hour in SNAPSHOT_TIMEZONE
RESET_HOUR_LOCAL=19
# Minutes before reset for pre-reset slot (e.g. 15 => 18:45)
PRE_RESET_OFFSET_MINUTES=15
# Optional early-trigger window start before reset:
# from (reset - PRE_RESET_WINDOW_START_MINUTES) to reset, runs are attributed to pre-reset slot above.
# Example: 20 => 18:40..18:59 runs map to 18:45.
PRE_RESET_WINDOW_START_MINUTES=20
# Skip snapshots for this many hours after reset hour
POST_RESET_SKIP_HOURS=2

# Optional one-off override guard for manual executions.
# Set a strong secret to allow payload-based force controls:
# - forceBypassDedupe: true
# - forceCaptureTimeUtc: "2026-02-18T17:00:00+00:00"
# - overrideToken: "<MANUAL_OVERRIDE_TOKEN>"
MANUAL_OVERRIDE_TOKEN=

# Parallel Appwrite writes for entries (use a small value to avoid API overload)
APPWRITE_WRITE_CONCURRENCY=6
